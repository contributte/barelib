{
  "name": "contributte/barelib",
  "description": "Template library for AI-driven Contributte package generation",
  "keywords": ["nette", "contributte", "template"],
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/contributte/barelib",
  "authors": [
    {
      "name": "Milan Felix Šulc",
      "homepage": "https://f3l1x.io"
    }
  ],
  "require": {
    "php": ">=8.2",
    "contributte/application": "^0.5.2 || ^0.6.0",
    "nette/di": "^3.2"
  },
  "require-dev": {
    "contributte/qa": "^0.4.0",
    "contributte/tester": "^0.3.0",
    "contributte/phpstan": "^0.2.0",
    "mockery/mockery": "^1.6.12"
  },
  "autoload": {
    "psr-4": {
      "Contributte\\Barelib\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.3.x-dev"
    }
  }
}
